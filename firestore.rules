rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owns(uid) { return signedIn() && request.auth.uid == uid; }

    match /users/{uid} {
      allow read, create, update, delete: if owns(uid);
    }

    match /leaderboards/{uid} {
      allow read: if true;
      allow create, update: if owns(uid)
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly([
          'uid','displayName','championships','matchWins','totalKOs',
          'longestStreak','bestBracket','damageDealt','fastestChampionship','updatedAt'
        ]);
      allow delete: if owns(uid);
    }
  }
}
